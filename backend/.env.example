# Agentic Growth OS - Backend Configuration

# Set to true to see debug logs
DEBUG=true

# NVIDIA NIM API configuration
# Register and fetch a free key at https://build.nvidia.com/
NVIDIA_API_KEY=

# Google Places API key for real business lead scraping
# Create a key at https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=

# Frontend URL for CORS (production)
FRONTEND_URL=https://your-frontend.vercel.app

# Database Connection String
# Defaults to a local SQLite database if left blank
# For Supabase/PostgreSQL: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL=
